# Dance DJ Pipeline Configuration

# Music folders
DANCE_INBOX_DIR=~/Music/DJ/inbox
DANCE_LIBRARY_DIR=~/Music/DJ/library
DANCE_STEMS_DIR=~/Music/DJ/stems

# Database location (SQLite)
DANCE_DATABASE_URL=sqlite:///data/dance.db

# Traktor collection path (auto-detected if not set)
# DANCE_TRAKTOR_COLLECTION=~/Documents/Native Instruments/Traktor Pro 4/collection.nml

# Processing options
DANCE_SKIP_STEMS=false
DANCE_SKIP_LLM=false
DANCE_MOVE_AFTER_PROCESSING=true

# LLM Configuration (Qwen2-Audio for tagging and validation)
# Set DANCE_SKIP_LLM=true to disable LLM augmentation
DANCE_LLM_MODEL=Qwen/Qwen2-Audio-7B-Instruct
DANCE_LLM_DEVICE=auto  # auto, mps (Mac), cuda (NVIDIA), cpu
DANCE_LLM_QUANTIZE=4bit  # 4bit, 8bit, or leave empty for full precision
DANCE_LLM_CACHE_RESPONSES=true

# Logging
DANCE_LOG_LEVEL=INFO
